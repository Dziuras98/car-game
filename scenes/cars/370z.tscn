[sub_resource type="Shader" id="Shader_details"]
code = "shader_type spatial;\n\nvarying vec3 model_position;\n\nvoid vertex() {\n\tmodel_position = VERTEX;\n}\n\nvoid fragment() {\n\tvec3 p = model_position;\n\tvec3 color = vec3(0.018, 0.023, 0.030);\n\tfloat metallic_value = 0.02;\n\tfloat roughness_value = 0.68;\n\n\tif (p.y > 0.86 && p.z > -0.72 && p.z < 1.02) {\n\t\tcolor = vec3(0.008, 0.013, 0.021);\n\t\tmetallic_value = 0.08;\n\t\troughness_value = 0.20;\n\t}\n\tif (p.z > 1.45 && p.y > 0.72) {\n\t\tcolor = vec3(0.68, 0.018, 0.035);\n\t\troughness_value = 0.24;\n\t}\n\tif (p.z < -1.18 && p.y > 0.63) {\n\t\tcolor = vec3(0.78, 0.83, 0.86);\n\t\tmetallic_value = 0.08;\n\t\troughness_value = 0.16;\n\t}\n\tif (p.z < -1.48 && abs(p.x) > 0.67 && p.y > 0.72) {\n\t\tcolor = vec3(0.95, 0.32, 0.025);\n\t\tmetallic_value = 0.0;\n\t\troughness_value = 0.20;\n\t}\n\tif (p.z < -2.07 && abs(p.x) > 0.69 && p.y > 0.25 && p.y < 0.59) {\n\t\tcolor = vec3(0.90, 0.95, 0.98);\n\t\tmetallic_value = 0.0;\n\t\troughness_value = 0.12;\n\t}\n\tif (p.z > 1.97 && p.y < 0.35 && abs(p.x) > 0.37 && abs(p.x) < 0.61) {\n\t\tcolor = vec3(0.58, 0.62, 0.66);\n\t\tmetallic_value = 0.78;\n\t\troughness_value = 0.23;\n\t}\n\tif (abs(p.x) > 0.90 && p.z > 0.28 && p.z < 0.42 && p.y > 0.74) {\n\t\tcolor = vec3(0.55, 0.58, 0.62);\n\t\tmetallic_value = 0.62;\n\t\troughness_value = 0.30;\n\t}\n\tif (p.z > 2.09 && abs(p.x) < 0.34 && p.y > 0.47) {\n\t\tcolor = vec3(0.10, 0.11, 0.13);\n\t\tmetallic_value = 0.0;\n\t\troughness_value = 0.48;\n\t}\n\n\tALBEDO = color;\n\tMETALLIC = metallic_value;\n\tROUGHNESS = roughness_value;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_details"]
shader = SubResource("Shader_details")

[sub_resource type="Shader" id="Shader_wheel"]
code = "shader_type spatial;\n\nvarying vec3 wheel_position;\n\nvoid vertex() {\n\twheel_position = VERTEX;\n}\n\nvoid fragment() {\n\tfloat radius = length(wheel_position.yz);\n\tvec3 color = vec3(0.43, 0.46, 0.49);\n\tfloat metallic_value = 0.62;\n\tfloat roughness_value = 0.31;\n\n\tif (radius > 0.255) {\n\t\tcolor = vec3(0.012, 0.012, 0.014);\n\t\tmetallic_value = 0.0;\n\t\troughness_value = 0.88;\n\t} else if (abs(wheel_position.x) < 0.135 && radius < 0.19) {\n\t\tcolor = vec3(0.20, 0.21, 0.23);\n\t\tmetallic_value = 0.58;\n\t\troughness_value = 0.43;\n\t}\n\n\tALBEDO = color;\n\tMETALLIC = metallic_value;\n\tROUGHNESS = roughness_value;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_wheel"]
