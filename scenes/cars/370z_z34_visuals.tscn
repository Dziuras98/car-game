[sub_resource type="Shader" id="DetailsShader"]
code = "shader_type spatial;\n\nvarying vec3 model_position;\n\nvoid vertex() { model_position = VERTEX; }\n\nvoid fragment() {\n\tvec3 p = model_position;\n\tvec3 color = vec3(0.018, 0.023, 0.030);\n\tfloat metallic_value = 0.02;\n\tfloat roughness_value = 0.68;\n\tif (p.y > 0.86 && p.z > -0.72 && p.z < 1.02) { color = vec3(0.008, 0.013, 0.021); metallic_value = 0.08; roughness_value = 0.20; }\n\tif (p.z > 1.45 && p.y > 0.72) { color = vec3(0.68, 0.018, 0.035); roughness_value = 0.24; }\n\tif (p.z < -1.18 && p.y > 0.63) { color = vec3(0.78, 0.83, 0.86); metallic_value = 0.08; roughness_value = 0.16; }\n\tif (p.z < -1.48 && abs(p.x) > 0.67 && p.y > 0.72) { color = vec3(0.95, 0.32, 0.025); metallic_value = 0.0; roughness_value = 0.20; }\n\tif (p.z < -2.07 && abs(p.x) > 0.69 && p.y > 0.25 && p.y < 0.59) { color = vec3(0.90, 0.95, 0.98); metallic_value = 0.0; roughness_value = 0.12; }\n\tif (p.z > 1.97 && p.y < 0.35 && abs(p.x) > 0.37 && abs(p.x) < 0.61) { color = vec3(0.58, 0.62, 0.66); metallic_value = 0.78; roughness_value = 0.23; }\n\tif (abs(p.x) > 0.90 && p.z > 0.28 && p.z < 0.42 && p.y > 0.74) { color = vec3(0.55, 0.58, 0.62); metallic_value = 0.62; roughness_value = 0.30; }\n\tif (p.z > 2.09 && abs(p.x) < 0.34 && p.y > 0.47) { color = vec3(0.10, 0.11, 0.13); metallic_value = 0.0; roughness_value = 0.48; }\n\tALBEDO = color; METALLIC = metallic_value; ROUGHNESS = roughness_value;\n}\n"

[sub_resource type="ShaderMaterial" id="DetailsMaterial"]
shader = SubResource("DetailsShader")

[sub_resource type="Shader" id="WheelShader"]
code = "shader_type spatial;\n\nvarying vec3 wheel_position;\nvoid vertex() { wheel_position = VERTEX; }\nvoid fragment() {\n\tfloat radius = length(wheel_position.yz);\n\tvec3 color = vec3(0.16, 0.17, 0.19);\n\tfloat metallic_value = 0.68;\n\tfloat roughness_value = 0.31;\n\tif (radius > 0.255) { color = vec3(0.012, 0.012, 0.014); metallic_value = 0.0; roughness_value = 0.88; }\n\telse if (abs(wheel_position.x) < 0.135 && radius < 0.19) { color = vec3(0.20, 0.21, 0.23); metallic_value = 0.58; roughness_value = 0.43; }\n\tALBEDO = color; METALLIC = metallic_value; ROUGHNESS = roughness_value;\n}\n"

[sub_resource type="ShaderMaterial" id="WheelMaterial"]
shader = SubResource("WheelShader")

