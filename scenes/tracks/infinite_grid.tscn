[sub_resource type="Shader" id="Shader_grid"]
code = "shader_type spatial;\nrender_mode unshaded, cull_disabled;\n\nuniform vec4 base_color : source_color = vec4(0.31, 0.32, 0.34, 1.0);\nuniform vec4 minor_line_color : source_color = vec4(1.0, 0.34, 0.03, 1.0);\nuniform vec4 major_line_color : source_color = vec4(0.86, 0.025, 0.015, 1.0);\nuniform float minor_spacing = 1.0;\nuniform float major_spacing = 10.0;\nuniform float minor_half_width = 0.025;\nuniform float major_half_width = 0.075;\n\nvarying vec3 world_position;\n\nfloat grid_mask(vec2 position, float spacing, float half_width) {\n\tvec2 cell_distance = abs(fract(position / spacing + 0.5) - 0.5) * spacing;\n\tvec2 antialias_width = max(fwidth(position), vec2(0.0005));\n\tvec2 line = 1.0 - smoothstep(\n\t\tvec2(half_width),\n\t\tvec2(half_width) + antialias_width,\n\t\tcell_distance\n\t);\n\treturn max(line.x, line.y);\n}\n\nvoid vertex() {\n\tworld_position = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;\n}\n\nvoid fragment() {\n\tfloat minor_grid = grid_mask(world_position.xz, minor_spacing, minor_half_width);\n\tfloat major_grid = grid_mask(world_position.xz, major_spacing, major_half_width);\n\tvec3 surface_color = mix(base_color.rgb, minor_line_color.rgb, minor_grid);\n\tsurface_color = mix(surface_color, major_line_color.rgb, major_grid);\n\tALBEDO = surface_color;\n\tROUGHNESS = 0.92;\n}\n"

